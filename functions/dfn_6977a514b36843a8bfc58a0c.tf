  code          = "// Learn more about destination functions API at\n// https://segment.com/docs/connections/destinations/destination-functions\n\n/**\n * Add a new Iterable customer/contact\n */\nasync function upsertUser(userId, traits, settings) {\n\tlet endpoint = `https://api.iterable.com/api/users/update`;\n\tlet response;\n\n\ttry {\n\t\tresponse = await fetch(endpoint, {\n\t\t\tmethod: 'POST',\n\t\t\theaders: {\n\t\t\t\t'Api-Key': settings.apiKey,\n\t\t\t\t'Content-Type': 'application/json'\n\t\t\t},\n\t\t\tbody: JSON.stringify({\n\t\t\t\tcreateNewFields: false,\n\t\t\t\tdataFields: traits,\n\t\t\t\temail: traits.email,\n\t\t\t\tmergeNestedObjects: true,\n\t\t\t\tpreferUserId: true,\n\t\t\t\tuserId: userId\n\t\t\t})\n\t\t});\n\t} catch (error) {\n\t\t// Retry on connection error\n\t\tthrow new RetryError(error.message);\n\t}\n\n\tif (response.status >= 500 || response.status === 429) {\n\t\t// Retry on 5xx (server errors) and 429s (rate limits)\n\t\tthrow new RetryError(`Failed with $${response.status}`);\n\t}\n\n\tconst responseJson = await response.json();\n\tconsole.log('upsertUser responseJson', responseJson);\n\treturn responseJson;\n}\n\n/**\n * Retrieve existing Iterable customer/contact by email userId (which is the customer_id, not wawa_digital_customer_id)\n */\nasync function getUserByUserId(userId, settings) {\n\tlet endpoint = `https://api.iterable.com/api/users/byUserId?userId=$${userId}`;\n\tlet response;\n\n\ttry {\n\t\tresponse = await fetch(endpoint, {\n\t\t\tmethod: 'GET',\n\t\t\theaders: {\n\t\t\t\t'Api-Key': settings.apiKey,\n\t\t\t\t'Content-Type': 'application/json'\n\t\t\t}\n\t\t});\n\t} catch (error) {\n\t\t// Retry on connection error\n\t\tthrow new RetryError(error.message);\n\t}\n\n\tif (response.status >= 500 || response.status === 429) {\n\t\t// Retry on 5xx (server errors) and 429s (rate limits)\n\t\tthrow new RetryError(`Failed with $${response.status}`);\n\t}\n\n\tconst responseJson = await response.json();\n\tconsole.log('getUserByUserId responseJson', responseJson);\n\treturn responseJson;\n}\n\n/**\n * Merge Iterable profile - replace old email address with new\n */\nasync function mergeUserProfile(oldEmail, newEmail, settings) {\n\tlet endpoint = `https://api.iterable.com/api/users/merge`;\n\tlet response;\n\n\ttry {\n\t\tresponse = await fetch(endpoint, {\n\t\t\tmethod: 'POST',\n\t\t\theaders: {\n\t\t\t\t'Api-Key': settings.apiKey,\n\t\t\t\t'Content-Type': 'application/json'\n\t\t\t},\n\t\t\tbody: JSON.stringify({\n\t\t\t\tsourceEmail: oldEmail,\n\t\t\t\tdestinationEmail: newEmail\n\t\t\t})\n\t\t});\n\t} catch (error) {\n\t\t// Retry on connection error\n\t\tthrow new RetryError(error.message);\n\t}\n\n\tif (response.status >= 500 || response.status === 429) {\n\t\t// Retry on 5xx (server errors) and 429s (rate limits)\n\t\tthrow new RetryError(`Failed with $${response.status}`);\n\t}\n\n\tconst responseJson = await response.json();\n\tconsole.log('mergeUserProfile responseJson', responseJson);\n\treturn responseJson;\n}\n\n/**\n * Iterable gives the option to update the email address either\n * by userId, or by the previous email address.\n */\nasync function updateUserEmail(userId, newEmail, settings) {\n\tlet endpoint = `https://api.iterable.com/api/users/updateEmail`;\n\tlet response;\n\n\ttry {\n\t\tresponse = await fetch(endpoint, {\n\t\t\tmethod: 'POST',\n\t\t\theaders: {\n\t\t\t\t'Api-Key': settings.apiKey,\n\t\t\t\t'Content-Type': 'application/json'\n\t\t\t},\n\t\t\tbody: JSON.stringify({\n\t\t\t\tcurrentUserId: userId,\n\t\t\t\tnewEmail: newEmail\n\t\t\t})\n\t\t});\n\t} catch (error) {\n\t\t// Retry on connection error\n\t\tthrow new RetryError(error.message);\n\t}\n\n\tif (response.status >= 500 || response.status === 429) {\n\t\t// Retry on 5xx (server errors) and 429s (rate limits)\n\t\tthrow new RetryError(`Failed with $${response.status}`);\n\t}\n\n\tconst responseJson = await response.json();\n\tconsole.log('updateUserEmail responseJson', responseJson);\n\treturn responseJson;\n}\n\n/**\n * Check for presence of retrieved user details in json returned from Iterable API - indicates valid user was retrieved\n */\nfunction containsUserObject(json) {\n\treturn 'user' in json;\n}\n\n/**\n * Handle identify event\n * @param  {SegmentIdentifyEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onIdentify(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/identify/\n\n\tconsole.log('In OnIdentify');\n\n\t//first check if a user with this customer ID already exists\n\tconst retrievedUserAccount = await getUserByUserId(\n\t\tencodeURIComponent(event.traits.customer_id),\n\t\tsettings\n\t);\n\n\t// Check if an account exists\n\tconst isAnExistingAccount = containsUserObject(retrievedUserAccount);\n\tif (isAnExistingAccount) {\n\t\t// if there is an existing account, check if email address has changed - if so, merge profiles\n\t\tif (\n\t\t\tevent.traits.email.toLowerCase() !==\n\t\t\tretrievedUserAccount.user.email.toLowerCase()\n\t\t) {\n\t\t\tconsole.log(\n\t\t\t\t'OnIdentify: Different email address found, merging profiles'\n\t\t\t);\n\n\t\t\t//await updateUserEmail(event.traits.customer_id, event.traits.email, settings);\n\n\t\t\tawait mergeUserProfile(\n\t\t\t\tretrievedUserAccount.user.email,\n\t\t\t\tevent.traits.email,\n\t\t\t\tsettings\n\t\t\t);\n\t\t}\n\t}\n\n\t//TODO: update subscriptions first\n\n\t//in any case, update the user account with the Account Created event properties\n\tawait upsertUser(event.traits.customer_id, event.traits, settings);\n}\n\n/**\n * Handle track event\n * @param  {SegmentTrackEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onTrack(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/track/\n\n\tconsole.log('In OnTrack');\n\n\tswitch (event.event) {\n\t\tcase 'Account Created':\n\t\t\tconsole.log('Account Created processing');\n\t\t\t//first check if a user with this customer ID already exists\n\t\t\tconst retrievedUserAccount = await getUserByUserId(\n\t\t\t\tencodeURIComponent(event.properties.customer_id),\n\t\t\t\tsettings\n\t\t\t);\n\n\t\t\t// Check if an account exists\n\t\t\tconst isAnExistingAccount = containsUserObject(retrievedUserAccount);\n\t\t\tif (isAnExistingAccount) {\n\t\t\t\t// if there is an existing account, check if email address has changed - if so, merge profiles\n\t\t\t\tif (\n\t\t\t\t\tevent.properties.email.toLowerCase() !==\n\t\t\t\t\tretrievedUserAccount.user.email.toLowerCase()\n\t\t\t\t) {\n\t\t\t\t\tconsole.log(\n\t\t\t\t\t\t'OnTrack - Account Created: Different email address found, merging profiles'\n\t\t\t\t\t);\n\n\t\t\t\t\t//await updateUserEmail(event.properties.customer_id, event.properties.email, settings);\n\n\t\t\t\t\tawait mergeUserProfile(\n\t\t\t\t\t\tretrievedUserAccount.user.email,\n\t\t\t\t\t\tevent.properties.email,\n\t\t\t\t\t\tsettings\n\t\t\t\t\t);\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t//TODO: update subscriptions first\n\n\t\t\t//in any case, update the user account with the Account Created event properties - need to remove redacted attributes first\n\t\t\tdelete event.properties.dob;\n\t\t\tdelete event.properties.gender;\n\t\t\tdelete event.properties.phone_number;\n\t\t\tawait upsertUser(\n\t\t\t\tevent.properties.customer_id,\n\t\t\t\tevent.properties,\n\t\t\t\tsettings\n\t\t\t);\n\n\t\t\tbreak;\n\t\tcase 'Account Updated':\n\t\t\tconsole.log('Account Updated processing');\n\n\t\t\t//first check if a user with this customer ID already exists (it should)\n\t\t\tconst accountUpdatedUser = await getUserByUserId(\n\t\t\t\tencodeURIComponent(event.properties.customer_id),\n\t\t\t\tsettings\n\t\t\t);\n\n\t\t\t// Check if the accountUpdatedUser object is empty (it shouldn't be)\n\t\t\tconst isAnExistingUserAccount = containsUserObject(accountUpdatedUser);\n\t\t\tif (isAnExistingUserAccount) {\n\t\t\t\t//user id was found, check if email address has changed - if so, merge profiles\n\t\t\t\tif (\n\t\t\t\t\tevent.properties.email.toLowerCase() !==\n\t\t\t\t\taccountUpdatedUser.user.email.toLowerCase()\n\t\t\t\t) {\n\t\t\t\t\tconsole.log(\n\t\t\t\t\t\t'OnTrack - Account Updated: Different email address found, merging profiles'\n\t\t\t\t\t);\n\n\t\t\t\t\t//await updateUserEmail(event.properties.customer_id, event.properties.email, settings);\n\n\t\t\t\t\tawait mergeUserProfile(\n\t\t\t\t\t\taccountUpdatedUser.user.email,\n\t\t\t\t\t\tevent.properties.email,\n\t\t\t\t\t\tsettings\n\t\t\t\t\t);\n\t\t\t\t}\n\t\t\t}\n\t\t\t//in any case, update the user account with the Account Updated event properties - remove redacted attributes first\n\t\t\tdelete event.properties.dob;\n\t\t\tdelete event.properties.gender;\n\t\t\tdelete event.properties.phone_number;\n\t\t\tawait upsertUser(\n\t\t\t\tevent.properties.customer_id,\n\t\t\t\tevent.properties,\n\t\t\t\tsettings\n\t\t\t);\n\t\t\tbreak;\n\t}\n}\n\n/**\n * Handle group event\n * @param  {SegmentGroupEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onGroup(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/group/\n\tthrow new EventNotSupported('group is not supported');\n}\n\n/**\n * Handle page event\n * @param  {SegmentPageEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onPage(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/page/\n\tthrow new EventNotSupported('page is not supported');\n}\n\n/**\n * Handle screen event\n * @param  {SegmentScreenEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onScreen(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/screen/\n\tthrow new EventNotSupported('screen is not supported');\n}\n\n/**\n * Handle alias event\n * @param  {SegmentAliasEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onAlias(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/alias/\n\tthrow new EventNotSupported('alias is not supported');\n}\n\n/**\n * Handle delete event\n * @param  {SegmentDeleteEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onDelete(event, settings) {\n\t// Learn more at https://segment.com/docs/partners/spec/#delete\n\tthrow new EventNotSupported('delete is not supported');\n}\n"
  description   = "When Segment receives an Identify event or Account Updated or Account Created Events, look up user in Iterable by customer_id. \nIf user exists:\nCompare the email on the Segment event to the user's Iterable email\nIf different, merge profiles in Iterable\nIf email is the same, do nothing but update Iterable user with the latest traits/ events from Segment"
