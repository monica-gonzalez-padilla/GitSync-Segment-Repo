  code          = "async function onTrack(event, settings) {\n\tconsole.log(JSON.stringify(event));\n\tlet new_event = { ...event }; //makes copy of the original, need to update all refence from event to new_event\n\tif (event.userId !== null && typeof event.userId !== 'undefined') {\n\t\tevent.properties.phone = event.userId; // Assign the value of event.userId to event.phone\n\t\tevent.userId = null; // Set event.userId to null\n\t}\n\n\t// Add a \"transformed\" flag for these events.\n\tevent.properties = { ...event.properties, migrated: true };\n\n\t// Delete some fields from the original event to ensure the event gets delivered with the original timestamp.\n\tdelete event.messageId;\n\tdelete event.writeKey;\n\tevent.writeKey = settings.writeKey; // Corrected the case of 'writeKey'\n\tdelete event.integrations;\n\tdelete event.protocols;\n\tdelete event.projectId;\n\tdelete event.receiveAt;\n\tdelete event.sentAt;\n\tdelete event.originalTimestamp;\n\tconsole.log(JSON.stringify(event));\n\n\tif (typeof event.anonymousId === 'undefined' || event.anonymousId === null) {\n\t\t// Generate a unique random value for anonymousId for server-side events. All events must have a userId or anonymousId.\n\t\tfunction generateUniqueRandomValue() {\n\t\t\t// Generate a random number between 0 and 999999 (adjust the range as needed)\n\t\t\tconst randomPart = Math.floor(Math.random() * 1000000);\n\t\t\t// Get the current timestamp in milliseconds\n\t\t\tconst timestamp = new Date().getTime();\n\t\t\t// Combine the random number and timestamp to create a unique value\n\t\t\tconst uniqueValue = `$${timestamp}-$${randomPart}`;\n\n\t\t\treturn uniqueValue;\n\t\t}\n\t\tconst uniqueRandomValue = generateUniqueRandomValue();\n\t\tconsole.log(uniqueRandomValue);\n\n\t\t// Assign the generated unique value to event.anonymousId\n\t\tevent.anonymousId = uniqueRandomValue;\n\t}\n\n\tconsole.log(event);\n\n\t// NOTE: Instead of random value generator,create unique UUID\n\t//const uuid = require('uuid');\n\t// Check if event.anonymousId exists\n\t//if (!event.anonymousId) {\n\t// Generate a new UUID and set it as event.anonymousId\n\t//event.anonymousId = uuid.v4();\n\t// Example usage\n\n\t// POST TRACK: Learn more at https://segment.com/docs/connections/spec/track/\n\tconst endpoint = 'https://api.segment.io/v1/track'; // send track event into segment source\n\tlet response;\n\n\ttry {\n\t\tresponse = await fetch(endpoint, {\n\t\t\tmethod: 'POST',\n\t\t\theaders: {\n\t\t\t\tAuthorization: `Basic $${btoa(settings.writeKey + ':')}`,\n\t\t\t\t'Content-Type': 'application/json'\n\t\t\t},\n\t\t\tbody: JSON.stringify(event)\n\t\t});\n\t} catch (error) {\n\t\t// Retry on connection error\n\t\tthrow new RetryError(error.message);\n\t}\n\n\tif (response.status >= 500 || response.status === 429) {\n\t\tconsole.log(`UserId: $${event.userId}: failed with $${response.status}`); // Logs original event Retry on 5xx (server errors) and 429s (rate limits)\n\t\tthrow new RetryError(`Failed with $${response.status}`);\n\t}\n\n\tconsole.log(event);\n}\n\n/** IDENTIFY EVENTS\n * Handle identify event\n * @param  {SegmentIdentifyEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onIdentify(event, settings) {\n\tif (event.userId !== null && typeof event.userId !== 'undefined') {\n\t\tevent.traits.phone = event.userId; // Assign the value of event.userId to event.traits.phone\n\t\tevent.userId = null; // Set event.userId to null\n\t}\n\n\t// Add a \"transformed\" flag for these events.\n\tevent.traits = { ...event.traits, migrated: true };\n\n\t// Delete some fields from the original event to ensure the event gets delivered with the original timestamp.\n\tdelete event.messageId;\n\tdelete event.writeKey;\n\tevent.writeKey = settings.writeKey; // Corrected the case of 'writeKey'\n\tdelete event.integrations;\n\tdelete event.protocols;\n\tdelete event.projectId;\n\tdelete event.receiveAt;\n\tdelete event.sentAt;\n\tdelete event.originalTimestamp;\n\n\tif (typeof event.anonymousId === 'undefined' || event.anonymousId === null) {\n\t\t// Generate a unique random value for anonymousId for server-side events. All events must have a userId or anonymousId.\n\t\tfunction generateUniqueRandomValue() {\n\t\t\t// Generate a random number between 0 and 999999 (adjust the range as needed)\n\t\t\tconst randomPart = Math.floor(Math.random() * 1000000);\n\t\t\t// Get the current timestamp in milliseconds\n\t\t\tconst timestamp = new Date().getTime();\n\t\t\t// Combine the random number and timestamp to create a unique value\n\t\t\tconst uniqueValue = `$${timestamp}-$${randomPart}`;\n\n\t\t\treturn uniqueValue;\n\t\t}\n\n\t\t// Example usage\n\t\tconst uniqueRandomValue = generateUniqueRandomValue();\n\t\tconsole.log(uniqueRandomValue);\n\n\t\t// Assign the generated unique value to event.anonymousId\n\t\tevent.anonymousId = uniqueRandomValue;\n\t}\n\n\tconsole.log(event);\n\n\t// Learn more at https://segment.com/docs/connections/spec/track/\n\tconst endpoint = 'https://api.segment.io/v1/identify'; // replace with your endpoint\n\tlet response;\n\n\ttry {\n\t\tresponse = await fetch(endpoint, {\n\t\t\tmethod: 'POST',\n\t\t\theaders: {\n\t\t\t\tAuthorization: `Basic $${btoa(settings.writeKey + ':')}`,\n\t\t\t\t'Content-Type': 'application/json'\n\t\t\t},\n\t\t\tbody: JSON.stringify(event)\n\t\t});\n\t} catch (error) {\n\t\t// Retry on connection error\n\t\tthrow new RetryError(error.message);\n\t}\n\n\tif (response.status >= 500 || response.status === 429) {\n\t\t// Retry on 5xx (server errors) and 429s (rate limits)\n\t\tthrow new RetryError(`Failed with $${response.status}`);\n\t}\n}\n"
