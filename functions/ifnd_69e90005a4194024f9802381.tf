  code          = "/**\n * Segment Destination Insert Function for Wawa -> Iterable\n */\n\nasync function onIdentify(event, settings) {\n\t// 1. Prioritize top-level userId (maps to Iterable System Field 'userId')\n\tconst lookupId = event.userId || event.traits?.customer_id;\n\tconst newEmail = event.traits?.email;\n\n\tconsole.log(`DIAGNOSTIC: Identify - ID: [$${lookupId}], Email: [$${newEmail}]`);\n\n\tif (lookupId && newEmail) {\n\t\tawait handleEmailChangeLogic(lookupId, newEmail, settings);\n\t}\n\treturn event;\n}\n\nasync function onTrack(event, settings) {\n\tconst targetEvents = ['Account Created', 'Account Updated'];\n\n\tif (targetEvents.includes(event.event)) {\n\t\t// Look for identifiers in properties for track events\n\t\tconst lookupId = event.userId || event.properties?.customer_id;\n\t\tconst newEmail = event.properties?.email;\n\n\t\tconsole.log(\n\t\t\t`DIAGNOSTIC: Track [$${event.event}] - ID: [$${lookupId}], Email: [$${newEmail}]`\n\t\t);\n\n\t\tif (lookupId && newEmail) {\n\t\t\tawait handleEmailChangeLogic(lookupId, newEmail, settings);\n\t\t}\n\n\t\t// Redact sensitive attributes for Wawa QA requirements\n\t\tif (event.properties) {\n\t\t\tdelete event.properties.dob;\n\t\t\tdelete event.properties.gender;\n\t\t\tdelete event.properties.phone_number;\n\t\t}\n\t}\n\treturn event;\n}\n\n/**\n * SHARED LOGIC: The Orchestrator\n */\nasync function handleEmailChangeLogic(lookupId, newEmail, settings) {\n\tconst cleanId = String(lookupId).trim();\n\tconst retrievedUser = await getUserByUserId(cleanId, settings);\n\n\tif (retrievedUser && retrievedUser.user) {\n\t\tconst oldEmail = retrievedUser.user.email;\n\n\t\t// Compare normalized emails\n\t\tif (oldEmail.toLowerCase() !== newEmail.toLowerCase()) {\n\t\t\tconsole.log(\n\t\t\t\t`ACTION: Email mismatch detected. Initiating Merge: $${oldEmail} -> $${newEmail}`\n\t\t\t);\n\t\t\tawait mergeUserProfile(oldEmail, newEmail, settings);\n\t\t} else {\n\t\t\tconsole.log(\n\t\t\t\t`STAY: Email matches Iterable record [$${oldEmail}]. No merge needed.`\n\t\t\t);\n\t\t}\n\t} else {\n\t\tconsole.log(\n\t\t\t`NOT FOUND: ID $${cleanId} doesn't exist in Iterable yet. Handing off to standard destination.`\n\t\t);\n\t}\n}\n\n/**\n * HELPER: GET user by userId\n */\nasync function getUserByUserId(userId, settings) {\n\tconst endpoint = `https://api.iterable.com/api/users/byUserId?userId=$${encodeURIComponent(userId)}`;\n\n\ttry {\n\t\tconst response = await fetch(endpoint, {\n\t\t\tmethod: 'GET',\n\t\t\theaders: { 'Api-Key': settings.apiKey }\n\t\t});\n\n\t\tif (response.status === 200) return await response.json();\n\t\tif (response.status === 404) return null;\n\n\t\tconsole.error(`ITERABLE LOOKUP ERROR: Status $${response.status}`);\n\t\treturn null;\n\t} catch (e) {\n\t\tthrow new RetryError(`Network error during lookup: $${e.message}`);\n\t}\n}\n\n/**\n * HELPER: POST merge profiles\n * Includes detailed response logging to catch \"Silent Failures\"\n */\nasync function mergeUserProfile(oldEmail, newEmail, settings) {\n\tconst endpoint = `https://api.iterable.com/api/users/merge`;\n\n\ttry {\n\t\tconst response = await fetch(endpoint, {\n\t\t\tmethod: 'POST',\n\t\t\theaders: {\n\t\t\t\t'Api-Key': settings.apiKey,\n\t\t\t\t'Content-Type': 'application/json'\n\t\t\t},\n\t\t\tbody: JSON.stringify({\n\t\t\t\tsourceEmail: oldEmail,\n\t\t\t\tdestinationEmail: newEmail.toLowerCase() // Force lowercase for consistency\n\t\t\t})\n\t\t});\n\n\t\tconst status = response.status;\n\t\tconst result = await response.json();\n\n\t\t// THIS LOG IS CRITICAL FOR DEBUGGING\n\t\tconsole.log(\n\t\t\t`ITERABLE MERGE RESPONSE [$${status}]: $${JSON.stringify(result)}`\n\t\t);\n\n\t\tif (status >= 500 || status === 429) {\n\t\t\tthrow new RetryError(`Iterable Merge temporary failure: $${status}`);\n\t\t}\n\n\t\treturn result;\n\t} catch (e) {\n\t\tif (e instanceof RetryError) throw e;\n\t\tconsole.error(`CRITICAL MERGE ERROR: $${e.message}`);\n\t}\n}\nasync function onGroup(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/group/\n\tthrow new EventNotSupported('group is not supported');\n}\n\n/**\n * Handle page event\n * @param  {SegmentPageEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onPage(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/page/\n\tthrow new EventNotSupported('page is not supported');\n}\n\n/**\n * Handle screen event\n * @param  {SegmentScreenEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onScreen(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/screen/\n\tthrow new EventNotSupported('screen is not supported');\n}\n\n/**\n * Handle alias event\n * @param  {SegmentAliasEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onAlias(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/alias/\n\tthrow new EventNotSupported('alias is not supported');\n}\n\n/**\n * Handle delete event\n * @param  {SegmentDeleteEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onDelete(event, settings) {\n\t// Learn more at https://segment.com/docs/partners/spec/#delete\n\tthrow new EventNotSupported('delete is not supported');\n}\n"
